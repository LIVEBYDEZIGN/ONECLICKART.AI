{
    "manifest_version": 3,
    "name": "ONECLICKART.AI",
    "version": "1.0",
    "description": "AI-powered artwork reinvention assistant for Pinterest, Etsy, Midjourney, Displate, and more — powered by Kie AI.",
    "icons": {
        "16": "favicon.png",
        "48": "favicon.png",
        "128": "favicon.png"
    },
    "action": {
        "default_title": "ONECLICKART.AI",
        "default_icon": "favicon.png"
    },
    "permissions": [
        "activeTab",
        "tabs",
        "storage",
        "downloads",
        "scripting",
        "contextMenus",
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "popup.html"
    },
    "host_permissions": [
        "*://*.pinterest.com/*",
        "*://*.etsy.com/*",
        "*://*.midjourney.com/*",
        "*://*.displate.com/*",
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "css": [
                "generic_content.css"
            ],
            "js": [
                "generic_content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "*://*.pinterest.com/*"
            ],
            "css": [
                "content.css"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "http://localhost/*",
                "https://*.netlify.app/*"
            ],
            "js": [
                "mama_banana_injector.js"
            ],
            "run_at": "document_idle"
        }
    ]
}